{
  "name": "@piwit/react-native-aws-waf-plugin",
  "version": "0.1.1",
  "description": "React Native wrapper for AWS WAF challenge.js — exposes WAF token acquisition at the JS app level via a hidden WebView bridge",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/src/index.d.ts",
  "files": [
    "lib/",
    "src/"
  ],
  "scripts": {
    "build": "bob build",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "prepare": "bob build"
  },
  "keywords": [
    "react-native",
    "aws",
    "waf",
    "challenge",
    "bot-protection",
    "webview"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.70.0",
    "react-native-webview": ">=13.0.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^12.4.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.2.0",
    "jest": "^29.7.0",
    "react": "^18.2.0",
    "react-native": "^0.74.0",
    "react-native-builder-bob": "^0.30.0",
    "react-native-webview": "^13.10.0",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.4.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  }
}
